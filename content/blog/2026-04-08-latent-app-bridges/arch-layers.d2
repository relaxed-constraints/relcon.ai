style.fill: transparent

grid-rows: 4
grid-columns: 1
grid-gap: 0

frontend: "Frontend  —  React (SPA) / Jinja2 (SSR)" {
  style.fill: "#e2e8f0"
  style.stroke: "#64748b"
  style.font-color: "#1e293b"
  style.border-radius: 0
}

api: "API Layer (REST/HTTP)  —  Stable contract, the fixture" {
  style.fill: "#dbeafe"
  style.stroke: "#64748b"
  style.font-color: "#1e293b"
  style.border-radius: 0
}

repo: "Repository / Data Layer  —  Swappable: SQL · MongoDB" {
  style.fill: "#d1fae5"
  style.stroke: "#64748b"
  style.font-color: "#1e293b"
  style.border-radius: 0
}

db: "Database  —  SQL or MongoDB" {
  style.fill: "#fde68a"
  style.stroke: "#64748b"
  style.font-color: "#1e293b"
  style.border-radius: 0
}
