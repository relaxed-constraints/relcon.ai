direction: right
style.fill: transparent

dataset: SQL\nDataset {
  shape: cylinder
  style.fill: "#336791"
  style.font-color: "#ffffff"
  style.stroke: "#274f6e"
}

llm: LLM {
  shape: rectangle
  width: 120
  height: 80
  style.fill: "#6C63FF"
  style.font-color: "#ffffff"
  style.stroke: "#5549cc"
}

app: Application {
  shape: package
  style.fill: "#14b8a6"
  style.font-color: "#ffffff"
  style.stroke: "#0d8c7b"
}

workload: SQL\nWorkload {
  shape: parallelogram
  style.fill: "#FF6B6B"
  style.font-color: "#ffffff"
  style.stroke: "#cc5555"
}

dataset -> llm: prompt
llm -> app: generates
app -> workload: derives
